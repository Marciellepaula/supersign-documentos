generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DocumentoStatus {
  pendente
  assinado
}

model Documento {
  id        String          @id @default(uuid())
  titulo    String
  descricao String?
  status    DocumentoStatus @default(pendente)
  criado_em DateTime        @default(now())

  @@map("documentos")
}
